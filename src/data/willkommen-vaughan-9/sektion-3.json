    { "id": "s3-g001", "front": "¿Qué son los verbos compuestos separables 'anmachen / ausmachen / aufmachen / zumachen'?", "back": "Son cuatro verbos formados por 'machen' (hacer) + un prefijo: an- (encender), aus- (apagar), auf- (abrir), zu- (cerrar). El prefijo se separa y va al final de la frase." },
    { "id": "s3-g002", "front": "¿Cómo se forma el imperativo 'tú' con un verbo separable como 'anmachen'?", "back": "Imperativo singular informal: Mach + objeto + prefijo. Ej: Mach den Computer an. El prefijo 'an' va al final." },
    { "id": "s3-g003", "front": "¿Cómo se forma el imperativo 'usted' con verbos separables?", "back": "Machen Sie + objeto + prefijo. Ej: Machen Sie das Licht aus. Igual estructura, pero conjugando 'machen' como en 'Sie'." },
    { "id": "s3-g004", "front": "¿Cómo se conjuga 'können' (poder) en presente?", "back": "ich kann, du kannst, er/sie/es kann, wir können, ihr könnt, sie/Sie können. Verbo modal." },
    { "id": "s3-g005", "front": "¿Cómo se forma '¿puedes...?' con un verbo separable?", "back": "Kannst du + objeto + verbo entero al final (infinitivo). Ej: Kannst du das Fenster aufmachen? El prefijo y el verbo no se separan cuando el verbo va al final como infinitivo." },
    { "id": "s3-g006", "front": "¿Cómo se forma '¿puede usted...?' con un verbo separable?", "back": "Können Sie + objeto + infinitivo del verbo separable al final. Ej: Können Sie den Kühlschrank zumachen?" },
    { "id": "s3-g007", "front": "¿Qué significa 'sollen' y cómo se usa para pedir instrucciones?", "back": "'sollen' = deber (en sentido de obligación o instrucción). En interrogativo significa '¿debo...?' o '¿quieres que...?'. Soll ich...? = ¿Enciendo/apago/abro/cierro yo...? Sollen wir...? = ¿Lo hacemos nosotros...?" },
    { "id": "s3-g008", "front": "¿Cómo se conjuga 'sollen'?", "back": "ich soll, du sollst, er/sie/es soll, wir sollen, ihr sollt, sie/Sie sollen. Verbo modal — el infinitivo del verbo principal va al final." },
    { "id": "s3-g009", "front": "¿Cómo se dice 'el cumpleaños es el X de Y' en alemán?", "back": "Mein Geburtstag ist am + ordinal-en + mes. Ej: Mein Geburtstag ist am dreizehnten Februar. La preposición 'am' = 'an dem' (en el)." },
    { "id": "s3-g010", "front": "¿Cómo se forman los ordinales en alemán (1-19 vs 20+)?", "back": "Del 1 al 19: número + -ten (con excepciones: erste, dritte, siebte, achte). Del 20 en adelante: número + -sten. Ej: 1. ersten, 3. dritten, 13. dreizehnten, 23. dreiundzwanzigsten, 30. dreißigsten." },
    { "id": "s3-g011", "front": "¿Qué ciudad visitamos en Sektion 3 y qué tiene de especial?", "back": "Schaffhausen — ciudad suiza (~36.000 habitantes), capital del cantón homónimo. También llamada 'Erkerstadt' (la ciudad de los miradores) por sus muchos edificios renacentistas. Cerca está la 'Rheinfallbrücke' (la cascada del Rin)." },
    { "id": "s3-g012", "front": "¿Qué significa 'Zoll'?", "back": "Aduana — letrero típico de control fronterizo. La palabra masculina." },
    { "id": "s3-g013", "front": "¿Quién fue Steffi Graf y de qué año es?", "back": "Tenista alemana (Tennisspielerin), nacida en Mannheim en 1969. Número 1 mundial 377 semanas. Ganó los 4 Grand Slams en el mismo año (1988) + oro olímpico (Golden Slam). Casada con Andre Agassi." },
    { "id": "s3-g014", "front": "¿Cuál es la versión más educada/formal de 'Tschüss'?", "back": "Auf Wiedersehen — literalmente '¡hasta la vista!'. Se usa con personas con las que se tiene un trato formal o que no se conocen mucho." },
    { "id": "s3-g015", "front": "Vocabulario clave — objetos del hogar (con género).", "back": "Masculinos: der Computer, der Fernseher, der Ventilator, der Schrank, der Kühlschrank, der Herd, der Balkon. Femeninos: die Heizung, die Musik, die Klimaanlage, die Tür, die Haustür, die Balkontür, die Schublade, die Kiste. Neutros: das Licht, das Radio, das Fenster, das Buch, das Gartentor, das Handy." },
    { "id": "s3-g016", "front": "Plurales de objetos cotidianos: Licht, Computer, Handy, Fenster, Tür, Schublade.", "back": "die Lichter, die Computer (sin cambio), die Handys, die Fenster (sin cambio), die Türen, die Schubladen. Schrank → die Schränke. Kiste → die Kisten." },
    { "id": "s3-g017", "front": "¿Cómo se reemplaza el complemento directo por un pronombre en estos verbos?", "back": "Acusativo: masculino 'der/den' → 'ihn', femenino 'die' → 'sie', neutro 'das' → 'es', plural 'die' → 'sie'. Ej: Mach den Fernseher an → Mach ihn an. Mach die Tür zu → Mach sie zu." }
  ]
}
