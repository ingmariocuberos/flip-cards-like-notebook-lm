    { "id": "s1-t064", "front": "Son las cinco menos cuarto.", "back": "Es ist viertel vor fünf." },
    { "id": "s1-t065", "front": "Son las once menos cuarto.", "back": "Es ist viertel vor elf." },
    { "id": "s1-t066", "front": "Son las siete menos cuarto.", "back": "Es ist viertel vor sieben." },
    { "id": "s1-t067", "front": "Son las doce menos cuarto.", "back": "Es ist viertel vor zwölf." },
    { "id": "s1-t068", "front": "Son las diez menos cuarto.", "back": "Es ist viertel vor zehn." },
