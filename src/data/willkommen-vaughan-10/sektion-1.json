  "cards": [
    { "id": "s1-t001", "front": "¿Cómo? (cuando no entiendes algo)", "back": "Wie bitte?" },
    { "id": "s1-t002", "front": "La carta es para mí.", "back": "Der Brief ist für mich." },
    { "id": "s1-t003", "front": "¿La carta es para mí?", "back": "Ist der Brief für mich?" },
    { "id": "s1-t004", "front": "¿Es para mí? (carta)", "back": "Ist er für mich?" },
    { "id": "s1-t005", "front": "Sí, es para ti.", "back": "Ja, er ist für dich." },
    { "id": "s1-t006", "front": "La postal es para mí.", "back": "Die Postkarte ist für mich." },
    { "id": "s1-t007", "front": "¿Es para mí? (postal)", "back": "Ist sie für mich?" },
    { "id": "s1-t008", "front": "Sí, es para ti. (postal)", "back": "Ja, sie ist für dich." },
    { "id": "s1-t009", "front": "El regalo es para mí.", "back": "Das Geschenk ist für mich." },
    { "id": "s1-t010", "front": "¿Es para mí? (regalo)", "back": "Ist es für mich?" },
    { "id": "s1-t011", "front": "Sí, es para ti. (regalo)", "back": "Ja, es ist für dich." },
    { "id": "s1-t012", "front": "No, no es para ti. (regalo)", "back": "Nein, das ist nicht für dich." },
    { "id": "s1-t013", "front": "Las flores son para mí.", "back": "Die Blumen sind für mich." },
    { "id": "s1-t014", "front": "¿Son para mí? (flores)", "back": "Sind sie für mich?" },
    { "id": "s1-t015", "front": "Sí, son para ti. (flores)", "back": "Ja, sie sind für dich." },
    { "id": "s1-t016", "front": "Los regalos son para mí.", "back": "Die Geschenke sind für mich." },
    { "id": "s1-t017", "front": "¿Son para mí? (regalos)", "back": "Sind sie für mich?" },
    { "id": "s1-t018", "front": "No, no son para ti. (regalos)", "back": "Nein, die sind nicht für dich." },

    { "id": "s1-t019", "front": "Urgencias (letrero de hospital)", "back": "Notaufnahme" },
    { "id": "s1-t020", "front": "Él me llama a menudo.", "back": "Er ruft mich oft an." },
    { "id": "s1-t021", "front": "Ella me llama todos los días.", "back": "Sie ruft mich jeden Tag an." },
    { "id": "s1-t022", "front": "Me llamas poco.", "back": "Du rufst mich selten an." },
    { "id": "s1-t023", "front": "Ahora te llamo.", "back": "Ich rufe dich gleich an." },
    { "id": "s1-t024", "front": "Luego te llama (él).", "back": "Er ruft dich später an." },
    { "id": "s1-t025", "front": "Te llamará pronto (ella).", "back": "Sie ruft dich bald an." },
    { "id": "s1-t026", "front": "Llámeme luego.", "back": "Rufen Sie mich später an." },
    { "id": "s1-t027", "front": "Llámeme mañana.", "back": "Rufen Sie mich morgen an." },
    { "id": "s1-t028", "front": "Llámeme esta noche.", "back": "Rufen Sie mich heute Abend an." },
    { "id": "s1-t029", "front": "¿Me puedes llamar mañana por la noche?", "back": "Kannst du mich morgen Abend anrufen?" },
    { "id": "s1-t030", "front": "¿Me puedes llamar luego?", "back": "Kannst du mich später anrufen?" },
    { "id": "s1-t031", "front": "¿Me puedes llamar enseguida?", "back": "Kannst du mich gleich anrufen?" },
    { "id": "s1-t032", "front": "¿Te puedo llamar mañana?", "back": "Kann ich dich morgen anrufen?" },
    { "id": "s1-t033", "front": "¿Te puedo llamar luego?", "back": "Kann ich dich später anrufen?" },
    { "id": "s1-t034", "front": "¿Te puedo llamar esta noche?", "back": "Kann ich dich heute Abend anrufen?" },

    { "id": "s1-t035", "front": "Te oigo bien.", "back": "Ich kann dich gut hören." },
    { "id": "s1-t036", "front": "No te oigo.", "back": "Ich kann dich nicht hören." },
    { "id": "s1-t037", "front": "No te oigo bien.", "back": "Ich kann dich nicht gut hören." },
    { "id": "s1-t038", "front": "Le oigo mal. (formal)", "back": "Ich kann Sie schlecht hören." },
    { "id": "s1-t039", "front": "Le oigo bien. (formal)", "back": "Ich kann Sie gut hören." },
    { "id": "s1-t040", "front": "No le oigo. (formal)", "back": "Ich kann Sie nicht hören." },
    { "id": "s1-t041", "front": "¿Me oyes?", "back": "Kannst du mich hören?" },
    { "id": "s1-t042", "front": "¿Me oyes mal?", "back": "Kannst du mich schlecht hören?" },
    { "id": "s1-t043", "front": "¿Me oyes bien?", "back": "Kannst du mich gut hören?" },
    { "id": "s1-t044", "front": "¿Me oye? (formal)", "back": "Können Sie mich hören?" },
    { "id": "s1-t045", "front": "¿Me oye bien? (formal)", "back": "Können Sie mich gut hören?" },
    { "id": "s1-t046", "front": "¿No me oye? (formal)", "back": "Können Sie mich nicht hören?" },
    { "id": "s1-t047", "front": "¿Me oyes? (sin können)", "back": "Hörst du mich?" },
    { "id": "s1-t048", "front": "¿Me oyes bien? (sin können)", "back": "Hörst du mich gut?" },
    { "id": "s1-t049", "front": "¿Me oye usted bien? (sin können)", "back": "Hören Sie mich gut?" },

