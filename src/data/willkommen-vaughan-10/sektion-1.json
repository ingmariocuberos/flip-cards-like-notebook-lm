    { "id": "s1-t060", "front": "Son las tres menos cuarto.", "back": "Es ist viertel vor drei." },
    { "id": "s1-t061", "front": "Son las nueve menos cuarto.", "back": "Es ist viertel vor neun." },
    { "id": "s1-t062", "front": "Son las dos menos cuarto.", "back": "Es ist viertel vor zwei." },
