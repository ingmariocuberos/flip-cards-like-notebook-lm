    { "id": "s1-t071", "front": "Te entiendo.", "back": "Ich verstehe dich." },
    { "id": "s1-t072", "front": "Le entiendo. (formal)", "back": "Ich verstehe Sie." },
    { "id": "s1-t073", "front": "Lo entiendo.", "back": "Ich verstehe es." },
    { "id": "s1-t074", "front": "No te entiendo.", "back": "Ich verstehe dich nicht." },
    { "id": "s1-t075", "front": "No le entiendo. (formal)", "back": "Ich verstehe Sie nicht." },
    { "id": "s1-t076", "front": "Ella no me entiende.", "back": "Sie versteht mich nicht." },
    { "id": "s1-t077", "front": "¿Me entiendes?", "back": "Verstehst du mich?" },
    { "id": "s1-t078", "front": "¿Me entiende usted?", "back": "Verstehen Sie mich?" },
    { "id": "s1-t079", "front": "¿Te entiendo yo a ti?", "back": "Verstehe ich dich?" },
    { "id": "s1-t080", "front": "Te comprendo. (uno te comprende)", "back": "Ich kann dich verstehen." },
    { "id": "s1-t081", "front": "Le comprendo. (formal)", "back": "Ich kann Sie verstehen." },
    { "id": "s1-t082", "front": "No lo comprendo / no lo entiendo.", "back": "Ich kann es nicht verstehen." },
    { "id": "s1-t083", "front": "¿Me comprendes?", "back": "Kannst du mich verstehen?" },
    { "id": "s1-t084", "front": "¿Me comprende usted?", "back": "Können Sie mich verstehen?" },
    { "id": "s1-t085", "front": "¿Me entiendes bien?", "back": "Kannst du mich gut verstehen?" },

    { "id": "s1-t086", "front": "Te voy a visitar pronto.", "back": "Ich besuche dich bald." },
    { "id": "s1-t087", "front": "Te voy a visitar en noviembre.", "back": "Ich besuche dich im November." },
    { "id": "s1-t088", "front": "Él va a visitarte en abril.", "back": "Er besucht dich im April." },
    { "id": "s1-t089", "front": "Te voy a visitar pronto. (con gehen)", "back": "Ich gehe dich bald besuchen." },
    { "id": "s1-t090", "front": "Voy a visitarte en noviembre. (con gehen)", "back": "Ich gehe dich im November besuchen." },
    { "id": "s1-t091", "front": "Ella te va a visitar en junio.", "back": "Sie geht dich im Juni besuchen." },
    { "id": "s1-t092", "front": "¿Cuándo me vienes a visitar?", "back": "Wann kommst du mich besuchen?" },
    { "id": "s1-t093", "front": "¿Cuándo me viene a visitar él?", "back": "Wann kommt er mich besuchen?" },
    { "id": "s1-t094", "front": "¿Cuándo me viene a visitar ella?", "back": "Wann kommt sie mich besuchen?" },
    { "id": "s1-t095", "front": "¿Cuándo vienes a visitar a tu hermano?", "back": "Wann kommst du deinen Bruder besuchen?" },
    { "id": "s1-t096", "front": "¿Cuándo vienes a visitar a tu novia?", "back": "Wann kommst du deine Freundin besuchen?" },
    { "id": "s1-t097", "front": "¿Cuándo vas a visitar a tus padres?", "back": "Wann gehst du deine Eltern besuchen?" },
    { "id": "s1-t098", "front": "¿Con qué frecuencia visitas a tus padres?", "back": "Wie oft gehst du deine Eltern besuchen?" },

    { "id": "s1-t099", "front": "Te quiero.", "back": "Ich liebe dich." },
    { "id": "s1-t100", "front": "¿Tú también me quieres?", "back": "Liebst du mich auch?" },
    { "id": "s1-t101", "front": "Tu novio no te quiere tampoco.", "back": "Dein Freund liebt dich auch nicht." },
    { "id": "s1-t102", "front": "¿Me quieres?", "back": "Liebst du mich?" },
    { "id": "s1-t103", "front": "Ella me quiere.", "back": "Sie liebt mich." },
    { "id": "s1-t104", "front": "Él no me quiere.", "back": "Er liebt mich nicht." },
    { "id": "s1-t105", "front": "¿Lo quieres? (a él)", "back": "Liebst du ihn?" },
    { "id": "s1-t106", "front": "Lo quiero. (a él)", "back": "Ich liebe ihn." },
    { "id": "s1-t107", "front": "Ella lo quiere. (a él)", "back": "Sie liebt ihn." },
    { "id": "s1-t108", "front": "¿La quieres? (a ella)", "back": "Liebst du sie?" },
    { "id": "s1-t109", "front": "Él la quiere. (a ella)", "back": "Er liebt sie." },
    { "id": "s1-t110", "front": "No la quiero. (a ella)", "back": "Ich liebe sie nicht." },
    { "id": "s1-t111", "front": "Te quiero, mamá. (cariñoso, liebhaben)", "back": "Ich hab dich lieb, Mutti." },
    { "id": "s1-t112", "front": "Lo quiero / le tengo cariño. (a él)", "back": "Ich hab ihn lieb." },
    { "id": "s1-t113", "front": "Ella le tiene cariño. (a él)", "back": "Sie hat ihn lieb." },

    { "id": "s1-g001", "front": "¿Qué pronombres acusativos aprendemos en Sektion 1?", "back": "mich (me/a mí), dich (te/a ti), ihn (lo/a él), sie (la/a ella), es (lo/neutro), Sie (le/a usted, formal). Misma forma para acusativo directo y después de 'für'." },
    { "id": "s1-g002", "front": "¿Qué caso introduce la preposición 'für'?", "back": "Acusativo. Por eso decimos: für mich, für dich, für ihn, für sie, für uns, für euch, für Sie." },
    { "id": "s1-g003", "front": "¿Cómo se conjuga 'hören' (oír) en presente?", "back": "ich höre, du hörst, er/sie/es hört, wir hören, ihr hört, sie/Sie hören. Verbo regular." },
    { "id": "s1-g004", "front": "¿Cómo se conjuga 'verstehen' (entender)?", "back": "ich verstehe, du verstehst, er/sie/es versteht, wir verstehen, ihr versteht, sie/Sie verstehen. Verbo regular (con prefijo inseparable 'ver-')." },
    { "id": "s1-g005", "front": "¿Cómo se conjuga 'besuchen' (visitar)?", "back": "ich besuche, du besuchst, er/sie/es besucht, wir besuchen, ihr besucht, sie/Sie besuchen. Regular, prefijo inseparable 'be-'." },
    { "id": "s1-g006", "front": "¿Cómo se conjuga 'lieben' (amar)?", "back": "ich liebe, du liebst, er/sie/es liebt, wir lieben, ihr liebt, sie/Sie lieben. Regular." },
    { "id": "s1-g007", "front": "¿Cuál es la diferencia entre 'lieben' y 'liebhaben'?", "back": "lieben = amar (sentido romántico fuerte). liebhaben = querer/tener cariño (más cotidiano, también para familia). Liebhaben es verbo compuesto separable: Ich hab dich lieb." },
    { "id": "s1-g008", "front": "¿Cómo se forma una pregunta como '¿cuándo me vienes a visitar?' con dos verbos?", "back": "Verbo conjugado + complemento acusativo + infinitivo al final. Wann kommst du mich besuchen? Wann gehst du deine Eltern besuchen? Estructura típica con 'kommen/gehen + verbo'." },
    { "id": "s1-g009", "front": "¿Cómo se dice 'menos cuarto' al dar la hora?", "back": "Es ist viertel vor + hora. La preposición 'vor' = antes de / menos. Ej: Es ist viertel vor drei = Son las tres menos cuarto." },
    { "id": "s1-g010", "front": "¿Cómo se forman los números 91-99 en alemán?", "back": "Patrón: unidad + und + neunzig. 91 einundneunzig, 92 zweiundneunzig… 99 neunundneunzig. 100 = hundert (sin 'eins')." },
    { "id": "s1-g011", "front": "¿Qué ciudad alemana visitamos en Sektion 1 y qué tiene de especial?", "back": "Essen — novena ciudad más poblada de Alemania (~570.000 habitantes), en Renania del Norte-Westfalia. Sede histórica del consorcio industrial Krupp. La 'Zollverein' (mina de carbón Zollverein) es Patrimonio de la Humanidad de la Unesco. Capital Europea de la Cultura 2010." },
    { "id": "s1-g012", "front": "¿Qué significa 'Notaufnahme'?", "back": "Urgencias (de un hospital). De 'Not' (apuro, emergencia) + 'Aufnahme' (admisión, recepción)." },
    { "id": "s1-g013", "front": "¿Qué se dice si no entiendes lo que alguien te dice y quieres que te lo repita?", "back": "Wie bitte? = ¿Cómo? / ¿Perdón? Es la versión educada. Decir solo '¿Was?' es algo brusco/maleducado." },
    { "id": "s1-g014", "front": "Plurales del 'Infierno' (Sektion 1): Besuch, Blume, Abend, Postkarte, Geschenk, Brief.", "back": "die Besuche (visitas), die Blumen (flores), die Abende (tardes/noches), die Postkarten (postales), die Geschenke (regalos), die Briefe (cartas)." },
    { "id": "s1-g015", "front": "Adverbios temporales clave de Sektion 1.", "back": "oft = a menudo, selten = poco/rara vez, gleich = enseguida, später = luego, bald = pronto, jeden Tag = todos los días, morgen = mañana, heute Abend = esta noche, im November/April/Juni = en noviembre/abril/junio." }
  ]
}
